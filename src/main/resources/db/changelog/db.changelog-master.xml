<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="001-create-saga-tables" author="codex">
        <sqlFile
            path="db/schema.sql"
            relativeToChangelogFile="false"
            splitStatements="true"
            stripComments="true"/>
    </changeSet>

    <changeSet id="001b-init-partitions" author="codex" runAlways="true">
        <sqlFile
            path="db/schema_partitions.sql"
            relativeToChangelogFile="false"
            splitStatements="false"
            stripComments="true"/>
    </changeSet>

    <changeSet id="002-add-waiting-state" author="codex">
        <sql>
            ALTER TABLE saga_execution
                ADD COLUMN IF NOT EXISTS waiting_state JSONB;
        </sql>
    </changeSet>

</databaseChangeLog>
